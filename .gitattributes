# Normalize all text files to LF.
* text=auto eol=lf

# Source files — always LF
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.md    text eol=lf
*.css   text eol=lf
*.html  text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf

# Windows-native — keep CRLF
*.ps1   text eol=crlf
*.bat   text eol=crlf
*.cmd   text eol=crlf

# Binary
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.webp  binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary

# Existing LFS rule (keep this)
public/data/products.json filter=lfs diff=lfs merge=lfs -text
